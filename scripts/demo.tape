# PropFlow — live demo, recorded with VHS (https://github.com/charmbracelet/vhs).
# Regenerate from the repo root, with the stack up and ANTHROPIC_API_KEY set:
#     vhs scripts/demo.tape
Output docs/assets/demo.gif

Set Shell "bash"
Set Theme "Catppuccin Mocha"
Set FontSize 14
Set Width 1200
Set Height 780
Set Padding 20
Set TypingSpeed 55ms
Set Framerate 20

Sleep 500ms
Type "npm run demo"
Sleep 500ms
Enter
Sleep 17s
