# Work Orders service
WORK_ORDERS_PORT=3001
WORK_ORDERS_DB_HOST=localhost
WORK_ORDERS_DB_PORT=5432
WORK_ORDERS_DB_USER=propflow
WORK_ORDERS_DB_PASSWORD=propflow
WORK_ORDERS_DB_NAME=work_orders

# Notifications service
NOTIFICATIONS_PORT=3002

# Properties service
PROPERTIES_PORT=3003
PROPERTIES_DB_HOST=localhost
PROPERTIES_DB_PORT=5432
PROPERTIES_DB_USER=propflow
PROPERTIES_DB_PASSWORD=propflow
PROPERTIES_DB_NAME=properties

# Audit service
AUDIT_PORT=3004
AUDIT_DB_HOST=localhost
AUDIT_DB_PORT=5432
AUDIT_DB_USER=propflow
AUDIT_DB_PASSWORD=propflow
AUDIT_DB_NAME=audit

# Messaging
RABBITMQ_URL=amqp://propflow:propflow@localhost:5672
KAFKA_BROKERS=localhost:9092

# AI triage (work-orders service) — leave the key unset to disable triage
# ANTHROPIC_API_KEY=sk-ant-...
TRIAGE_MODEL=claude-opus-4-8

# Outbox relay poll interval (work-orders service)
OUTBOX_POLL_MS=500

# Authentication (api-gateway)
# JWT_SECRET=change-me-to-a-long-random-string
# Demo users as email:password:role CSV — omit to use the built-in trio
# AUTH_USERS=manager@propflow.dev:propflow:manager,tenant@propflow.dev:propflow:tenant,tech@propflow.dev:propflow:technician
